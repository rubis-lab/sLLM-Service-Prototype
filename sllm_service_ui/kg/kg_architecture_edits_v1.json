            },
            "task_variant_assignments": {
              "VST": {
                "cognitive_mapping": {
                  "name": "central discrimination",
                  "definition": "현재 주시 중인 item을 중심시야/foveal 정보로 target인지 distractor인지 판별하는 과정",
                  "literature_insight": "et_fixation_duration_mean ↑ → central discrimination 부담 ↑ → 선택주의력 ↓"
                },
                "interpretation": {
                  "higher_value": {
                    "summary": "fixation 지속시간 증가",
                    "cognitive_meaning": "central discrimination 과정에서 target/distractor 판별 부담 증가 가능성",
                    "behavior_proxy_meaning": "선택주의력 저하와 관련된 보조 소견으로 해석 가능"
                  },
                  "lower_value": {
                    "summary": "fixation 지속시간 감소 또는 지연 근거 약함",
                    "cognitive_meaning": "central discrimination 지연의 근거는 상대적으로 약함",
                    "behavior_proxy_meaning": "낮은 값만으로 선택주의력이 우수하다고 단정하지 않음"
                  }
                },
                "evidence": {
                  "reference_ids": [
                    "Canu_2022"
                  ]
                },
                "report_template": {
                  "high_value_phrase": "VST에서 et_fixation_duration_mean이 높게 나타난 경우, 한 번의 fixation 동안 현재 주시 중인 item을 중심시야/foveal 정보로 target인지 distractor인지 판별하는 central discrimination 과정이 상대적으로 길어졌을 가능성을 시사합니다. 이는 선택주의력 관련 보조 소견으로 해석할 수 있습니다.",
                  "low_value_phrase": "VST에서 et_fixation_duration_mean이 낮게 나타난 경우, central discrimination 지연을 시사하는 근거는 상대적으로 약합니다. 다만 낮은 값만으로 선택주의력이 우수하다고 단정하지 않고, 정확도, 반응시간, target miss와 함께 해석해야 합니다."
