    "first_fixation_duration": {
      "x": 2180,
      "y": 110,
      "w": 365,
      "h": 74,
      "label": "et_first_fixation_duration_mean",
      "sublabel": "",
      "footnote": "",
      "highlight": true,
      "details": {
        "node": {
          "name": "et_first_fixation_duration_mean",
          "layer": "Primitive Indicator Layer",
          "definition": "자극 제시 이후 첫 fixation의 지속시간 평균",
          "unit": "ms",
          "measurement": {
            "modality": "eye_tracking"
          }
        },
        "edge_bundles": {
          "selective_attention_to_et_first_fixation_duration_mean": {
            "from": {
              "layer": "Behavior Proxy Layer",
              "name": "선택주의력"
            },
            "to": {
              "layer": "Primitive Indicator Layer",
              "name": "et_first_fixation_duration_mean"
            },
            "task_variant_assignments": {
              "VST": {
                "cognitive_mapping": {
                  "name": "automatic processing",
                  "definition": "자극이 처음 시야에 들어왔을 때 빠르고 비교적 자동적으로 일어나는 초기 처리 및 주의 끌림 과정",
                  "literature_insight": "et_first_fixation_duration_mean ↑ → automatic processing 부담 ↑ → 선택주의력 ↓"
                },
                "interpretation": {
                  "higher_value": {
                    "summary": "첫 fixation 지속시간 증가",
                    "cognitive_meaning": "automatic processing 단계에서 초기 처리 또는 주의 끌림 부담 증가 가능성",
                    "behavior_proxy_meaning": "선택주의력 저하와 관련된 보조 소견으로 해석 가능"
                  },
                  "lower_value": {
                    "summary": "첫 fixation 지속시간 감소 또는 지연 근거 약함",
                    "cognitive_meaning": "automatic processing 지연의 근거는 상대적으로 약함",
                    "behavior_proxy_meaning": "낮은 값만으로 선택주의력이 우수하다고 단정하지 않음"
                  }
                },
                "evidence": {
                  "reference_ids": [
                    "Cui_2020"
                  ]
                },
                "report_template": {
                  "high_value_phrase": "VST에서 et_first_fixation_duration_mean이 높게 나타난 경우, 자극 제시 직후 첫 fixation의 지속시간이 길어진 소견으로 볼 수 있습니다. 이는 automatic processing 단계에서 초기 처리 또는 주의 끌림 부담이 증가했을 가능성을 시사하며, 선택주의력 관련 보조 소견으로 해석할 수 있습니다.",
                  "low_value_phrase": "VST에서 et_first_fixation_duration_mean이 낮게 나타난 경우, automatic processing 지연을 시사하는 근거는 상대적으로 약합니다. 다만 낮은 값만으로 선택주의력이 우수하다고 단정하지 않습니다."
                }
              }
            }
          }
        },
        "references": {
          "Cui_2020": {
            "authors": [
              "Cui",
