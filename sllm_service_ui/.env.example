# SLLM service UI runtime configuration
# Copy this file to .env and edit values for your machine.

# Optional OpenAI settings. Leave OPENAI_API_KEY empty to hide OpenAI models.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Web server
HOST=0.0.0.0
PORT=8788

# Ollama local model backend
OLLAMA_MODEL=gemma4:e4b
QWEN_14_MODEL=qwen3:14b
OLLAMA_URL=http://127.0.0.1:11534
OLLAMA_BIN=.local/ollama/bin/ollama
OLLAMA_MODELS=.local/ollama_models
SKIP_OLLAMA=0
PULL_MODELS=0
PULL_QWEN_14=0

# Hugging Face / PEFT backend
HF_ENABLED=1
HF_AUTOSTART=0
HF_MODEL_ID=google/gemma-4-E4B-it
HF_MODEL_VALUE=hf:google/gemma-4-E4B-it
HF_BACKEND_URL=http://127.0.0.1:8896
HF_BACKEND_SCRIPT=server_handoff_20260501/app/hf_transformers_server.py
HF_PYTHON_EXE=python
HF_DEVICE_MAP=cuda:0
HF_DEVICE=cuda:0
HF_DTYPE=bfloat16
HF_LOAD_IN_4BIT=0
HF_MAX_NEW_TOKENS=2048
HF_HUB_DISABLE_XET=1
HF_CUDA_VISIBLE_DEVICES=0

# Fine-tuned adapter exposed in the UI.
# Relative paths are resolved from this sllm_service_ui directory.
HF_FT3_MODEL_VALUE=hf:gemma-4-E4B-it_ft_v3
HF_FT3_DISPLAY_NAME=gemma4:E4B
HF_FT3_ADAPTER_DIR=../model/adapter

# Structured summary lookup
PROTOTYPE_SUMMARY_ROOT=../data_preprocessing/summary
CLIENT_DEMOGRAPHICS_FILE=../data_preprocessing/clients_metadata.csv
HOSPITAL_DATA_REAL_DIR=../pdss_data

# PDF export
REPORT_PDF_PYTHON=python
REPORT_PDF_SCRIPT=tools/report_pdf.py
PDF_FONT_PATH=assets/fonts/NanumGothic-Regular.ttf
PDF_BOLD_FONT_PATH=assets/fonts/NanumGothic-Bold.ttf
